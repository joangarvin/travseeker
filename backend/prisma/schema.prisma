datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Destino {
  id                    String      @id @default(uuid())
  nombre                String
  tipoTurismoPrincipal  String
  tipoTurismoSecundario String
  presupuesto           String
  masificacion          String
  mesesJulioAgosto      Int
  mesesNovAbril         Int
  mesesMayJunSeptOct    Int
  destinosItem          String?
  ubicacion             String
  descripcion           String
  imprescindibles       String
  imagen                String
  latitud               Float?
  longitud              Float?

  municipios            Municipio[]
  favoritos             Favorito[]
  reviews               Review[]
  collectionItems       CollectionItem[]
}

model Municipio {
  id              String  @id @default(uuid())
  nombre          String
  precios         String
  conexiones      String
  tipoTurismo     String?

  destinoId       String?
  destino         Destino? @relation(fields: [destinoId], references: [id])
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  nombre        String?
  apellidos     String?
  avatarUrl     String?
  bio           String?
  role          String    @default("user")
  locale        String    @default("es")
  preferences   Json?
  metadata      Json?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  favoritos     Favorito[]
  reviews       Review[]
  tokens        VerificationToken[]
  collections   Collection[]
}

model Collection {
  id          String   @id @default(uuid())
  userId      String
  nombre      String
  descripcion String?
  color       String   @default("emerald")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CollectionItem[]

  @@index([userId])
}

model CollectionItem {
  id           String   @id @default(uuid())
  collectionId String
  destinoId    String
  notas        String?
  createdAt    DateTime @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  destino      Destino    @relation(fields: [destinoId], references: [id], onDelete: Cascade)

  @@unique([collectionId, destinoId])
  @@index([collectionId])
  @@index([destinoId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  destinoId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  destino   Destino  @relation(fields: [destinoId], references: [id], onDelete: Cascade)

  @@unique([userId, destinoId])
  @@index([destinoId])
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  type      String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Favorito {
  id        String   @id @default(uuid())
  userId    String
  destinoId String
  notas     String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  destino   Destino  @relation(fields: [destinoId], references: [id], onDelete: Cascade)

  @@unique([userId, destinoId])
  @@index([userId])
  @@index([destinoId])
}
