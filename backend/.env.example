# PostgreSQL (Neon, Supabase, Railway, local…)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/travseeker?schema=public"

# Secreto para firmar JWT (genera uno largo y aleatorio en producción)
JWT_SECRET="cambia-esto-por-un-secreto-seguro"

# Puerto del servidor (Render/Railway lo inyectan automáticamente)
PORT=3001

# URL pública del frontend (enlaces en emails de verificación/recuperación)
APP_URL="https://tudominio.com"

# Origen permitido por CORS (normalmente igual que APP_URL)
FRONTEND_URL="https://tudominio.com"

# SMTP opcional para emails reales (si no se configura, se loguean en consola)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# MAIL_FROM="TravSeeker <no-reply@tudominio.com>"
